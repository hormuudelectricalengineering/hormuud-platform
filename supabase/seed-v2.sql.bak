-- Payment for completed job
INSERT INTO public.payments (id, job_id, amount, method, status, created_at)
VALUES 
  ('11111111-1111-1111-1111-000000000010', '55555555-5555-5555-5555-000000000005', 75.00, 'ebirr', 'completed', NOW() - interval '20 hours');

COMMIT;

-- Verify
SELECT 'Jobs' as category, COUNT(*) as count FROM public.jobs WHERE id::text LIKE '%00000%'
UNION ALL SELECT 'Pending', COUNT(*) FROM public.jobs WHERE status = 'pending'
UNION ALL SELECT 'Active', COUNT(*) FROM public.jobs WHERE status IN ('assigned', 'in_progress')
UNION ALL SELECT 'Completed', COUNT(*) FROM public.jobs WHERE status = 'completed'
UNION ALL SELECT 'Engineers', COUNT(*) FROM public.engineers WHERE is_verified = true
UNION ALL SELECT 'Online', COUNT(*) FROM public.engineers WHERE is_online = true;