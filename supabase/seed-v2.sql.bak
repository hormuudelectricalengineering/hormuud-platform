-- Now insert jobs (separate transaction as it depends on above)
BEGIN;

-- Clean up existing test jobs
DELETE FROM public.payments WHERE job_id::text LIKE '%00000%';
DELETE FROM public.jobs WHERE id::text LIKE '%00000%';

-- 2 PENDING jobs
INSERT INTO public.jobs (id, customer_id, engineer_id, service_category, status, address, lat, lng, estimated_price, created_at, updated_at)
VALUES 
  ('11111111-1111-1111-1111-000000000001', '00000000-0000-0000-0000-000000000001', NULL, 'Electrical Repair', 'pending', 'Bakara Market, Mogadishu', 2.0419, 45.3122, 50.00, NOW() - interval '2 hours', NOW() - interval '2 hours'),
  
  ('22222222-2222-2222-2222-000000000002', '00000000-0000-0000-0000-000000000002', NULL, 'AC Installation', 'pending', 'Hodan District, Mogadishu', 2.0519, 45.3222, 150.00, NOW() - interval '1 hour', NOW() - interval '1 hour');

