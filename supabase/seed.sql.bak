-- Verify data
SELECT 
  'Engineers' as table_name, COUNT(*) as count FROM public.engineers WHERE is_verified = true
UNION ALL
SELECT 
  'Online Engineers', COUNT(*) FROM public.engineers WHERE is_online = true
UNION ALL
SELECT 
  'Pending Jobs', COUNT(*) FROM public.jobs WHERE status = 'pending'
UNION ALL
SELECT 
  'Active Jobs', COUNT(*) FROM public.jobs WHERE status IN ('assigned', 'in_progress')
UNION ALL
SELECT 
  'Completed Jobs', COUNT(*) FROM public.jobs WHERE status = 'completed'
UNION ALL
SELECT 
  'Customers', COUNT(*) FROM public.profiles WHERE role = 'customer';