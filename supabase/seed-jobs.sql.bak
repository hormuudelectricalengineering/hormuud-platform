-- Simple seed data for testing - uses raw SQL that works with Supabase
-- Run this via Supabase Studio SQL Editor or via psql

-- First, let's create test users in auth.users (we'll use a workaround)
-- Then create profiles and other data

-- For testing, we'll work with just the jobs table which doesn't require auth.users

-- Clean up existing test data
DELETE FROM public.payments WHERE job_id::text LIKE '%00000%';
DELETE FROM public.jobs WHERE id::text LIKE '%00000%';

-- Insert 2 PENDING jobs
